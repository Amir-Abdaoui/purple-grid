# =============================================================================
# Purple-Grid · backend-api · .dockerignore
#
# PURPOSE: Reduce the Docker build context sent to the daemon.
#
# WHY THIS MATTERS — two distinct reasons:
#   1. SECURITY : secrets, keys, and tokens must NEVER reach the build context.
#      Even if a Dockerfile never COPYs a secret file, it still exists inside
#      the build context tarball. Any layer (including intermediate ones cached
#      locally) could expose it via `docker history` or a mis-written COPY glob.
#   2. PERFORMANCE : a bloated build context (e.g., including .git history,
#      node_modules, or a local venv with thousands of files) forces the Docker
#      daemon to hash every file before it can start processing the Dockerfile.
#      This alone can add 10–30 seconds to every build on a large project.
# =============================================================================

# ── Version control ────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes
.github/

# ── Python runtime artifacts ───────────────────────────────────────────────────
# Virtual environments — can be gigabytes; deps are installed fresh in the build.
.venv/
venv/
env/
ENV/
__pypackages__/

# Bytecode — regenerated at runtime; including them is wasteful and can cause
# hard-to-debug "stale bytecode" issues when source changes aren't picked up.
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging artifacts
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Test & quality tooling ─────────────────────────────────────────────────────
# These directories are dev-only; they must not ship in a production image.
tests/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/

# ── Secrets & credentials — CRITICAL ──────────────────────────────────────────
# These patterns must NEVER enter the build context under any circumstance.
# If you find yourself needing to pass secrets at build time, use
# Docker BuildKit secret mounts (`--secret id=...`) instead.
.env
.env.*
*.env
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_ed25519
*.pub
.ssh/
secrets/
credentials/
*.secret
*_secret*
*secret*
kubeconfig
.kube/

# ── IDE / editor files ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker files themselves ────────────────────────────────────────────────────
# The Dockerfile is read by the daemon before the context is assembled;
# including it in the context itself is redundant.
Dockerfile*
docker-compose*.yml
.dockerignore

# ── CI/CD pipeline definitions ────────────────────────────────────────────────
.github/
.gitlab-ci.yml
Jenkinsfile
.circleci/
.travis.yml

# ── Documentation ─────────────────────────────────────────────────────────────
README.md
CHANGELOG.md
docs/
*.md

# ── Miscellaneous ─────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
.make/
Makefile